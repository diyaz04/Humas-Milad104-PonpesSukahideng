{
  "entities": {
    "Setting": {
      "title": "Site Settings",
      "description": "Global configuration for the website content",
      "type": "object",
      "properties": {
        "heroTitle": { "type": "string" },
        "heroTagline": { "type": "string" },
        "countdownDate": { "type": "string", "format": "date-time" },
        "aboutTitle": { "type": "string" },
        "aboutText": { "type": "string" }
      },
      "required": ["heroTitle", "heroTagline", "countdownDate"]
    },
    "News": {
      "title": "News & Announcements",
      "description": "News items displayed on the landing page",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "content": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "imageUrl": { "type": "string" }
      },
      "required": ["title", "content", "date"]
    },
    "ScheduleItem": {
      "title": "Agenda Item",
      "description": "Events in the milad schedule",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "startTime": { "type": "string" },
        "endTime": { "type": "string" },
        "location": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string" }
      },
      "required": ["name", "date", "startTime"]
    },
    "Koorwil": {
      "title": "Koorwil",
      "description": "Regional coordinators for alumni groups",
      "type": "object",
      "properties": {
        "name": { "type": "string" }
      },
      "required": ["name"]
    },
    "Sport": {
      "title": "Sport Category",
      "description": "Types of sports/arts in PORSAS",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "category": { "type": "string", "enum": ["olahraga", "seni"] },
        "gender": { "type": "string", "enum": ["putra", "putri", "umum"] },
        "type": { "type": "string", "enum": ["individu", "tim"] }
      },
      "required": ["name", "category", "gender", "type"]
    },
    "Registration": {
      "title": "PORSAS Registration",
      "description": "Registration for PORSAS",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "koorwil": { "type": "string" },
        "sportId": { "type": "string" },
        "sportName": { "type": "string" },
        "category": { "type": "string", "enum": ["olahraga", "seni"] },
        "gender": { "type": "string", "enum": ["putra", "putri"] },
        "members": { "type": "string" },
        "contact": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "sportId", "sportName", "category", "gender", "members", "contact"]
    },
    "Product": {
      "title": "Merchandise Product",
      "description": "Products available for purchase",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "price": { "type": "number" },
        "image": { "type": "string", "description": "Image URL or base64" },
        "description": { "type": "string" },
        "isActive": { "type": "boolean" }
      },
      "required": ["name", "price", "isActive"]
    },
    "ProductOrder": {
      "title": "Merchandise Order",
      "description": "Orders placed by users",
      "type": "object",
      "properties": {
        "productId": { "type": "string" },
        "productName": { "type": "string" },
        "customerName": { "type": "string" },
        "customerContact": { "type": "string" },
        "address": { "type": "string" },
        "quantity": { "type": "number" },
        "totalPrice": { "type": "number" },
        "paymentProof": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "verified", "rejected"] },
        "timestamp": { "type": "string", "format": "date-time" },
        "orderCode": { "type": "string" }
      },
      "required": ["productId", "customerName", "customerContact", "quantity", "status", "orderCode"]
    },
    "MerchantConfig": {
      "title": "Merchant Configuration",
      "description": "Bank details for merchandise payments",
      "type": "object",
      "properties": {
        "bankName": { "type": "string" },
        "accountNumber": { "type": "string" },
        "accountName": { "type": "string" }
      }
    },
    "Match": {
      "title": "PORSAS Match",
      "description": "A single match in the tournament bracket",
      "type": "object",
      "properties": {
        "sportId": { "type": "string" },
        "round": { "type": "number" },
        "matchIndex": { "type": "number" },
        "teamAId": { "type": "string" },
        "teamBId": { "type": "string" },
        "scoreA": { "type": "number" },
        "scoreB": { "type": "number" },
        "winnerId": { "type": "string" },
        "status": { "type": "string", "enum": ["scheduled", "ongoing", "completed"] },
        "startTime": { "type": "string", "format": "date-time" }
      }
    },
    "Alumnus": {
      "title": "Alumnus",
      "description": "Database of alumni for confirmation and check-in",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "yearIn": { "type": "string" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "village": { "type": "string" },
        "district": { "type": "string" },
        "city": { "type": "string" },
        "province": { "type": "string" },
        "profession": { "type": "string" },
        "status": { "type": "string", "enum": ["unconfirmed", "confirmed", "checked-in"] },
        "registrationCode": { "type": "string" },
        "confirmedAt": { "type": "string", "format": "date-time" },
        "checkedInAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "yearIn", "status"]
    },
    "Document": {
      "title": "Document Resource",
      "description": "PDF resources such as Juknis or Proposals",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "url": { "type": "string" },
        "category": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "url"]
    },
    "VenuePoint": {
      "title": "Venue Point",
      "description": "Activity location points with coordinates",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "latitude": { "type": "number" },
        "longitude": { "type": "number" },
        "category": { "type": "string", "enum": ["utama", "parkir", "makan", "istirahat", "porsas", "lainnya"] },
        "icon": { "type": "string" }
      },
      "required": ["name", "latitude", "longitude", "category"]
    },
    "VenueRoute": {
      "title": "Venue Route",
      "description": "Path/route for activities like gowes or jalan santai",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "type": { "type": "string", "enum": ["gowes", "jalan-santai", "pawai"] },
        "points": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "lat": { "type": "number" },
              "lng": { "type": "number" }
            }
          }
        },
        "color": { "type": "string" },
        "distance": { "type": "string" }
      },
      "required": ["name", "type", "points"]
    },
    "Wish": {
      "title": "Anniversary Wish",
      "description": "Messages sent by alumni, students, and public",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "role": { "type": "string", "enum": ["alumni", "santri", "umum"] },
        "angkatan": { "type": "string" },
        "message": { "type": "string" },
        "template": { "type": "number" },
        "likes": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "approved"] },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "role", "message", "template", "status", "timestamp"]
    }
  },
  "firestore": {
    "settings/general": {
      "schema": "Setting",
      "description": "Main settings document"
    },
    "news": {
      "schema": "News",
      "description": "Collection of news items"
    },
    "schedule": {
      "schema": "ScheduleItem",
      "description": "Collection of schedule events"
    },
    "koorwils": {
      "schema": "Koorwil",
      "description": "List of available koorwils"
    },
    "sports": {
      "schema": "Sport",
      "description": "List of available sports"
    },
    "registrations": {
      "schema": "Registration",
      "description": "Submitted team registrations"
    },
    "matches": {
      "schema": "Match",
      "description": "Tournament bracket matches"
    },
    "alumni": {
      "schema": "Alumnus",
      "description": "Database of alumni and their attendance status"
    },
    "documents": {
      "schema": "Document",
      "description": "Publicly accessible documents like PDF rules or proposals"
    },
    "venue_points": {
      "schema": "VenuePoint",
      "description": "Points of interest for the event map/layout"
    },
    "venue_routes": {
      "schema": "VenueRoute",
      "description": "Tracking paths for gowes, walking, etc."
    },
    "wishes": {
      "schema": "Wish",
      "description": "Public wishes and messages for the 104th anniversary"
    }
  }
}
