rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Testing venue_routes availability
    match /venue_routes/{docId} {
      allow read, write: if true;
    }

    function isAdmin() {
      return request.auth != null && (
        request.auth.token.email == 'miladponpessukahideng@gmail.com' ||
        request.auth.token.email == 'adminmilad104@milad104.com'
      );
    }

    function isValidId(id) {
       return id is string && id.size() <= 128;
    }

    // Documents (Juknis & Proposal)
    match /documents/{docId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // Settings
    match /settings/{docId} {
      allow read: if true;
      allow write: if true; // Just code access required
    }

    // News
    match /news/{docId} {
      allow read: if true;
      allow write: if true;
    }

    // Schedule
    match /schedule/{docId} {
      allow read: if true;
      allow write: if true;
    }

    // FAQ
    match /faqs/{docId} {
      allow read: if true;
      allow write: if true;
    }

    // PORSAS Master Data
    match /koorwils/{docId} {
      allow read: if true;
      allow write: if true;
    }
    match /sports/{docId} {
      allow read: if true;
      allow write: if true;
    }

    // PORSAS Dynamic Data
    match /registrations/{docId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if true;
    }
    match /matches/{docId} {
      allow read: if true;
      allow write: if true;
    }

    // Merchandise
    match /products/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /productOrders/{docId} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }

    // Donations
    match /donations/{docId} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }

    // Venue Points (Denah) - Public Read
    match /venue_points/{pointId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Alumni Database & Confirmation
    match /alumni/{alumniId} {
      allow create: if true;
      allow read: if true; // Searching by name needs read access
      allow update: if true; // Alumni can edit their data
      allow delete: if request.auth != null; // Only admin can delete
    }
  }
}
