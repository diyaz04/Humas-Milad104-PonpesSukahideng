rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Deny
    match /{document=**} {
      allow read, write: if false;
    }

    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'miladponpessukahideng@gmail.com';
    }

    function isValidId(id) {
       return id is string && id.size() <= 128;
    }

    // Settings
    match /settings/{docId} {
      allow read: if true;
      allow write: if true; // Just code access required
    }

    // News
    match /news/{docId} {
      allow read: if true;
      allow write: if true;
    }

    // Schedule
    match /schedule/{docId} {
      allow read: if true;
      allow write: if true;
    }

    // FAQ
    match /faqs/{docId} {
      allow read: if true;
      allow write: if true;
    }

    // PORSAS Master Data
    match /koorwils/{docId} {
      allow read: if true;
      allow write: if true;
    }
    match /sports/{docId} {
      allow read: if true;
      allow write: if true;
    }

    // PORSAS Dynamic Data
    match /registrations/{docId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if true;
    }
    match /matches/{docId} {
      allow read: if true;
      allow write: if true;
    }

    // Merchandise
    match /products/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /productOrders/{docId} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }
  }
}
